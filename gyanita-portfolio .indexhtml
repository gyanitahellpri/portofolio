<!DOCTYPE html>
<html lang="id" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gyanita Helldyah Prihanto | Frontend Developer</title>
  <meta name="description" content="Portfolio Gyanita Helldyah Prihanto — Frontend Web Developer dari Indramayu, Jawa Barat." />
  <meta property="og:title" content="Gyanita Helldyah Prihanto | Frontend Developer" />
  <meta property="og:description" content="I build clean, responsive web interfaces focused on user experience." />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    :root {
      --bg: #0d0d0f;
      --bg2: #13131a;
      --bg3: #1a1a24;
      --border: rgba(255,255,255,0.08);
      --border2: rgba(255,255,255,0.14);
      --text: #f0f0f0;
      --text2: #9a9aaa;
      --text3: #5a5a6a;
      --accent: #7c6aff;
      --accent2: #a091ff;
      --accent-glow: rgba(124,106,255,0.18);
      --accent-bg: rgba(124,106,255,0.1);
      --green: #4ade80;
      --card: #13131a;
      --nav-bg: rgba(13,13,15,0.85);
    }
    [data-theme="light"] {
      --bg: #f8f8fb;
      --bg2: #ffffff;
      --bg3: #f0f0f5;
      --border: rgba(0,0,0,0.08);
      --border2: rgba(0,0,0,0.14);
      --text: #111118;
      --text2: #55556a;
      --text3: #aaaabd;
      --accent: #5b4adf;
      --accent2: #7c6aff;
      --accent-glow: rgba(91,74,223,0.12);
      --accent-bg: rgba(91,74,223,0.08);
      --card: #ffffff;
      --nav-bg: rgba(248,248,251,0.88);
    }

    html{scroll-behavior:smooth}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:16px;line-height:1.7;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s}

    /* SCROLLBAR */
    ::-webkit-scrollbar{width:5px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--accent);border-radius:99px}

    /* NOISE OVERLAY */
    body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:.4}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:200;background:var(--nav-bg);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
    .nav-inner{max-width:1100px;margin:0 auto;padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Fira Code',monospace;font-size:14px;color:var(--accent);text-decoration:none;letter-spacing:.02em}
    .nav-logo span{color:var(--text2)}
    .nav-links{display:flex;gap:2rem;list-style:none;align-items:center}
    .nav-links a{font-size:13px;color:var(--text2);text-decoration:none;transition:color .2s;font-weight:400;letter-spacing:.01em}
    .nav-links a:hover{color:var(--accent)}
    .nav-right{display:flex;align-items:center;gap:1rem}
    .theme-btn{background:none;border:1px solid var(--border2);border-radius:8px;padding:7px 10px;cursor:pointer;color:var(--text2);font-size:14px;transition:all .2s;line-height:1}
    .theme-btn:hover{border-color:var(--accent);color:var(--accent)}
    .nav-menu-btn{display:none;background:none;border:none;cursor:pointer;padding:4px;color:var(--text);flex-direction:column;gap:5px}
    .nav-menu-btn span{display:block;width:22px;height:1.5px;background:currentColor;transition:all .25s}

    /* HERO */
    #home{min-height:100vh;display:flex;align-items:center;padding:0 2rem;max-width:1100px;margin:0 auto;padding-top:64px}
    .hero-inner{display:grid;grid-template-columns:1fr auto;gap:5rem;align-items:center;width:100%}
    .hero-left{max-width:580px}
    .hero-greeting{font-family:'Fira Code',monospace;font-size:13px;color:var(--accent);margin-bottom:1.25rem;display:flex;align-items:center;gap:8px}
    .hero-greeting::before{content:'';display:block;width:32px;height:1px;background:var(--accent)}
    .hero-name{font-size:clamp(36px,6vw,62px);font-weight:600;letter-spacing:-.03em;line-height:1.1;margin-bottom:.5rem;color:var(--text)}
    .hero-role{font-size:clamp(20px,3vw,32px);font-weight:300;letter-spacing:-.02em;color:var(--text2);margin-bottom:1.5rem;min-height:42px}
    .cursor{display:inline-block;width:2px;height:1em;background:var(--accent);margin-left:2px;vertical-align:middle;animation:blink .7s infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
    .hero-desc{font-size:16px;color:var(--text2);line-height:1.8;font-weight:300;margin-bottom:2.5rem;max-width:460px}
    .hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:3rem}
    .btn-accent{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:var(--accent);color:#fff;font-size:14px;font-weight:500;border-radius:10px;text-decoration:none;transition:all .2s;border:none;cursor:pointer}
    .btn-accent:hover{opacity:.88;transform:translateY(-2px);box-shadow:0 8px 24px var(--accent-glow)}
    .btn-ghost{display:inline-flex;align-items:center;gap:8px;padding:11px 28px;background:transparent;color:var(--text);font-size:14px;font-weight:400;border-radius:10px;border:1px solid var(--border2);text-decoration:none;transition:all .2s}
    .btn-ghost:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}
    .hero-socials{display:flex;gap:16px}
    .hero-social{color:var(--text3);text-decoration:none;font-size:13px;font-family:'Fira Code',monospace;transition:color .2s;display:flex;align-items:center;gap:6px}
    .hero-social:hover{color:var(--accent)}
    .hero-social svg{width:16px;height:16px;fill:currentColor}

    /* HERO PHOTO */
    .hero-photo-wrap{position:relative;flex-shrink:0}
    .hero-photo-ring{width:300px;height:420px;border-radius:24px;background:linear-gradient(135deg,var(--accent),transparent 60%);padding:2px;position:relative}
    .hero-photo-inner{width:100%;height:100%;border-radius:22px;overflow:hidden;background:var(--bg2)}
    .hero-photo-inner img{width:100%;height:100%;object-fit:cover;object-position:center top}
    .hero-badge{position:absolute;bottom:-16px;right:-8px;background:var(--bg2);border:1px solid var(--border2);border-radius:12px;padding:10px 14px;display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text2)}
    .hero-badge-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 2s infinite}
    @keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.2);opacity:.7}}

    /* WRAPPER */
    .container{max-width:1100px;margin:0 auto;padding:0 2rem}

    /* SECTION */
    .section{padding:7rem 0}
    .section-tag{font-family:'Fira Code',monospace;font-size:12px;color:var(--accent);letter-spacing:.1em;margin-bottom:1rem;display:flex;align-items:center;gap:10px}
    .section-tag::after{content:'';flex:1;max-width:60px;height:1px;background:var(--accent);opacity:.4}
    .section-h{font-size:clamp(24px,3.5vw,34px);font-weight:600;letter-spacing:-.025em;color:var(--text);margin-bottom:1rem}
    .section-sub{font-size:15px;color:var(--text2);font-weight:300;line-height:1.8;max-width:500px}

    /* DIVIDER */
    .divider{border:none;border-top:1px solid var(--border);margin:0 2rem}

    /* ABOUT */
    .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start;margin-top:3rem}
    .about-photo-col{position:relative}
    .about-photo-frame{border-radius:20px;overflow:hidden;border:1px solid var(--border2);position:relative}
    .about-photo-frame img{width:100%;height:420px;object-fit:cover;object-position:center top;display:block}
    .about-photo-frame::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,var(--bg) 0%,transparent 40%);pointer-events:none}
    .about-text-col{}
    .about-desc{font-size:15px;color:var(--text2);line-height:1.9;font-weight:300;margin-bottom:1rem}
    .about-desc strong{color:var(--text);font-weight:500}
    .about-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:2rem}
    .about-info-item{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:1rem}
    .about-info-label{font-family:'Fira Code',monospace;font-size:10px;color:var(--text3);letter-spacing:.08em;margin-bottom:4px}
    .about-info-value{font-size:13px;color:var(--text);font-weight:400}

    /* SKILLS */
    .skills-marquee-wrap{overflow:hidden;margin-top:2.5rem;position:relative}
    .skills-marquee-wrap::before,.skills-marquee-wrap::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none}
    .skills-marquee-wrap::before{left:0;background:linear-gradient(to right,var(--bg),transparent)}
    .skills-marquee-wrap::after{right:0;background:linear-gradient(to left,var(--bg),transparent)}
    .skills-track{display:flex;gap:12px;animation:marquee 28s linear infinite;width:max-content}
    .skills-track:hover{animation-play-state:paused}
    @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .skill-pill{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;background:var(--bg2);border:1px solid var(--border);border-radius:999px;font-size:13px;color:var(--text2);white-space:nowrap;transition:all .2s;cursor:default;flex-shrink:0}
    .skill-pill:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-bg)}
    .skill-pill-icon{font-size:16px}
    .skills-grid-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-top:2rem}
    .skill-card-v2{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:1.25rem;text-align:center;transition:all .2s;cursor:default}
    .skill-card-v2:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 12px 28px var(--accent-glow)}
    .skill-card-v2 .sk-icon{font-size:28px;margin-bottom:10px}
    .skill-card-v2 .sk-name{font-size:13px;font-weight:500;color:var(--text);margin-bottom:2px}
    .skill-card-v2 .sk-sub{font-family:'Fira Code',monospace;font-size:10px;color:var(--text3)}

    /* PROJECTS */
    .projects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;margin-top:2.5rem}
    .project-card{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:1.75rem;display:flex;flex-direction:column;gap:14px;transition:all .25s;position:relative;overflow:hidden}
    .project-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,var(--accent-glow),transparent 60%);opacity:0;transition:opacity .3s}
    .project-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.3)}
    .project-card:hover::before{opacity:1}
    .project-header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
    .project-icon{width:44px;height:44px;border-radius:12px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
    .project-links-top{display:flex;gap:8px}
    .project-link-icon{color:var(--text3);text-decoration:none;transition:color .2s;font-size:13px;font-family:'Fira Code',monospace;padding:4px 10px;border:1px solid var(--border);border-radius:6px}
    .project-link-icon:hover{color:var(--accent);border-color:var(--accent)}
    .project-num{font-family:'Fira Code',monospace;font-size:11px;color:var(--text3)}
    .project-title{font-size:18px;font-weight:600;letter-spacing:-.01em;color:var(--text)}
    .project-desc{font-size:14px;color:var(--text2);line-height:1.7;font-weight:300;flex:1}
    .project-tags{display:flex;flex-wrap:wrap;gap:6px}
    .ptag{font-family:'Fira Code',monospace;font-size:11px;padding:4px 10px;background:var(--accent-bg);color:var(--accent2);border-radius:6px;border:1px solid rgba(124,106,255,.2)}

    /* CONTACT */
    .contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:5rem;margin-top:3rem;align-items:start}
    .contact-info{}
    .contact-desc{font-size:15px;color:var(--text2);font-weight:300;line-height:1.8;margin-bottom:2rem}
    .contact-detail-list{display:flex;flex-direction:column;gap:16px;margin-bottom:2.5rem}
    .contact-detail{display:flex;align-items:center;gap:14px}
    .contact-detail-icon{width:40px;height:40px;border-radius:10px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;border:1px solid rgba(124,106,255,.2)}
    .contact-detail-text{}
    .contact-detail-label{font-family:'Fira Code',monospace;font-size:10px;color:var(--text3);letter-spacing:.06em}
    .contact-detail-val{font-size:14px;color:var(--text);font-weight:400}
    .contact-detail-val a{color:var(--text);text-decoration:none;transition:color .2s}
    .contact-detail-val a:hover{color:var(--accent)}
    .contact-socials{display:flex;gap:10px}
    .social-btn{width:42px;height:42px;border-radius:10px;background:var(--bg2);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;color:var(--text2);text-decoration:none;font-size:18px;transition:all .2s}
    .social-btn:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}

    /* FORM */
    .contact-form{background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:2rem;display:flex;flex-direction:column;gap:16px}
    .form-group{display:flex;flex-direction:column;gap:6px}
    .form-group label{font-family:'Fira Code',monospace;font-size:11px;color:var(--text3);letter-spacing:.06em}
    .form-group input,.form-group textarea{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 14px;font-size:14px;color:var(--text);font-family:'Inter',sans-serif;resize:none;transition:border-color .2s;outline:none}
    .form-group input:focus,.form-group textarea:focus{border-color:var(--accent)}
    .form-group textarea{min-height:120px}
    .form-submit{padding:13px;background:var(--accent);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;transition:all .2s;font-family:'Inter',sans-serif}
    .form-submit:hover{opacity:.88;transform:translateY(-1px)}
    .form-note{font-size:12px;color:var(--text3);text-align:center}

    /* MUSIC */
    .music-bar{position:fixed;bottom:1.5rem;right:1.5rem;z-index:150;background:var(--bg2);border:1px solid var(--border2);border-radius:14px;padding:10px 16px;display:flex;align-items:center;gap:10px;backdrop-filter:blur(12px)}
    .music-bars{display:flex;align-items:flex-end;gap:3px;height:16px}
    .music-bar-line{width:3px;border-radius:99px;background:var(--accent)}
    .music-bar-line:nth-child(1){height:6px;animation:bar 1.1s ease-in-out infinite}
    .music-bar-line:nth-child(2){height:12px;animation:bar 1.1s ease-in-out .2s infinite}
    .music-bar-line:nth-child(3){height:8px;animation:bar 1.1s ease-in-out .4s infinite}
    .music-bar-line:nth-child(4){height:14px;animation:bar 1.1s ease-in-out .1s infinite}
    @keyframes bar{0%,100%{transform:scaleY(1)}50%{transform:scaleY(.4)}}
    .music-btn{background:none;border:none;cursor:pointer;color:var(--text2);font-size:13px;font-family:'Fira Code',monospace;transition:color .2s;display:flex;align-items:center;gap:6px;padding:0}
    .music-btn:hover{color:var(--accent)}
    .music-label{font-family:'Fira Code',monospace;font-size:11px;color:var(--text3)}
    .music-paused .music-bar-line{animation-play-state:paused}

    /* FOOTER */
    footer{border-top:1px solid var(--border);padding:2.5rem 2rem}
    .footer-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
    .footer-copy{font-family:'Fira Code',monospace;font-size:12px;color:var(--text3)}
    .footer-links{display:flex;gap:1.5rem}
    .footer-links a{font-size:13px;color:var(--text3);text-decoration:none;transition:color .2s}
    .footer-links a:hover{color:var(--accent)}

    /* REVEAL */
    .reveal{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    /* MOBILE */
    @media(max-width:768px){
      .hero-inner{grid-template-columns:1fr;text-align:center;gap:3rem;padding:2rem 0}
      .hero-photo-wrap{order:-1;display:flex;justify-content:center}
      .hero-photo-ring{width:200px;height:280px}
      .hero-socials{justify-content:center}
      .hero-btns{justify-content:center}
      .hero-greeting{justify-content:center}
      .about-grid{grid-template-columns:1fr}
      .about-photo-col{display:none}
      .contact-wrap{grid-template-columns:1fr}
      .nav-links{display:none}
      .nav-links.open{display:flex;flex-direction:column;gap:0;position:fixed;top:64px;left:0;right:0;background:var(--bg);border-bottom:1px solid var(--border);padding:1rem 2rem}
      .nav-links.open li a{padding:14px 0;display:block;border-bottom:1px solid var(--border)}
      .nav-menu-btn{display:flex}
      .music-bar{display:none}
      .section{padding:5rem 0}
    }
  </style>
</head>
<body>

<audio id="lofi-audio" loop>
  <source src="https://lofi.stream.laut.fm/lofi" type="audio/mpeg" />
</audio>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#home" class="nav-logo">&lt;<span>GHP</span> /&gt;</a>
    <div class="nav-right">
      <ul class="nav-links" id="navLinks">
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#education">Education</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <button class="theme-btn" id="themeBtn" title="Toggle theme">🌙</button>
      <button class="nav-menu-btn" id="menuBtn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- HERO -->
<section id="home">
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-greeting">Hi, I'm</div>
      <div class="hero-name">Gyanita Helldyah<br/>Prihanto</div>
      <div class="hero-role" id="heroRole"><span id="typed"></span><span class="cursor"></span></div>
      <p class="hero-desc">Mahasiswa Sistem Informasi Kota Cerdas di Politeknik Negeri Indramayu yang passionate di bidang web development. Saya membangun antarmuka web yang bersih, fungsional, dan berorientasi pada pengguna.</p>
      <div class="hero-btns">
        <a href="#projects" class="btn-accent">View My Work</a>
        <a href="https://github.com/gyanitahellpri" target="_blank" rel="noopener" class="btn-ghost">My GitHub</a>
        <a href="data:application/pdf;base64," download="CV_Gyanita_Helldyah_Prihanto.pdf" class="btn-ghost">Download CV ↓</a>
      </div>
      <div class="hero-socials">
        <a href="https://github.com/gyanitahellpri" class="hero-social" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          GitHub
        </a>
        <a href="https://instagram.com/" class="hero-social" target="_blank" rel="noopener">
