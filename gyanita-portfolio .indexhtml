<!-- MUSIC PLAYER -->
<div class="music-bar" id="musicBar">
  <div class="music-bars music-paused" id="musicViz">
    <div class="music-bar-line"></div>
    <div class="music-bar-line"></div>
    <div class="music-bar-line"></div>
    <div class="music-bar-line"></div>
  </div>
  <div>
    <div class="music-label">Lofi Radio</div>
    <button class="music-btn" id="musicBtn">▶ Play</button>
  </div>
</div>

<script>
  // TYPING
  const roles = ['Frontend Developer', 'UI/UX Enthusiast', 'Smart City Student', 'Web Creator'];
  let ri = 0, ci = 0, deleting = false;
  const typedEl = document.getElementById('typed');
  function type() {
    const word = roles[ri];
    typedEl.textContent = deleting ? word.substring(0, ci--) : word.substring(0, ci++);
    let delay = deleting ? 50 : 90;
    if (!deleting && ci > word.length) { delay = 1600; deleting = true; }
    else if (deleting && ci < 0) { deleting = false; ri = (ri + 1) % roles.length; ci = 0; delay = 400; }
    setTimeout(type, delay);
  }
  type();

  // THEME
  const themeBtn = document.getElementById('themeBtn');
  let dark = true;
  themeBtn.addEventListener('click', () => {
    dark = !dark;
    document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
    themeBtn.textContent = dark ? '🌙' : '☀️';
  });

  // MOBILE MENU
  const menuBtn = document.getElementById('menuBtn');
  const navLinks = document.getElementById('navLinks');
  menuBtn.addEventListener('click', () => navLinks.classList.toggle('open'));
  navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));

  // SKILLS MARQUEE
  const skills = [
    {icon:'🌐',name:'HTML'},{icon:'🎨',name:'CSS'},{icon:'🗄️',name:'MySQL'},
    {icon:'🖌️',name:'Figma'},{icon:'📊',name:'Microsoft Excel'},{icon:'📝',name:'Microsoft Word'},
    {icon:'🧠',name:'Analitis'},{icon:'🤝',name:'Kolaborasi'},{icon:'🏙️',name:'Smart City'},
    {icon:'💡',name:'Problem Solving'},{icon:'🎯',name:'UI/UX'},{icon:'📱',name:'Responsive Design'},
  ];
  const track = document.getElementById('skillsTrack');
  const doubled = [...skills, ...skills, ...skills, ...skills];
  doubled.forEach(s => {
    const el = document.createElement('div');
    el.className = 'skill-pill';
    el.innerHTML = `<span class="skill-pill-icon">${s.icon}</span>${s.name}`;
    track.appendChild(el);
  });

  // SCROLL REVEAL
  const reveals = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 80);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => obs.observe(el));

  // HERO ENTRANCE
  ['hero-greeting','hero-name','hero-role','hero-desc','hero-btns','hero-socials','hero-photo-wrap'].forEach((cls, i) => {
    const el = document.querySelector('.'+cls);
    if(!el) return;
    el.style.cssText = 'opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease';
    setTimeout(() => { el.style.opacity=1; el.style.transform='translateY(0)'; }, 120 + i*110);
  });

  // MUSIC
  const audio = document.getElementById('lofi-audio');
  const musicBtn = document.getElementById('musicBtn');
  const musicViz = document.getElementById('musicViz');
  let playing = false;
  musicBtn.addEventListener('click', () => {
    if (playing) { audio.pause(); musicBtn.textContent = '▶ Play'; musicViz.classList.add('music-paused'); }
    else { audio.play().catch(()=>{}); musicBtn.textContent = '⏸ Pause'; musicViz.classList.remove('music-paused'); }
    playing = !playing;
  });

  // FORM
  document.getElementById('sendBtn').addEventListener('click', () => {
    const note = document.getElementById('formNote');
    note.textContent = '✅ Pesan terkirim! Saya akan segera menghubungi kamu.';
    note.style.color = '#4ade80';
    setTimeout(() => { note.textContent = ''; }, 4000);
  });
</script>
</body>
</html>
